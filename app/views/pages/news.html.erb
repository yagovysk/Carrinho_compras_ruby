<section class="rounded-3xl border border-slate-200 bg-white/90 p-6 shadow-sm sm:p-8">
  <h2 class="text-2xl font-extrabold text-slate-900 sm:text-3xl"><%= t('pages.news.title') %></h2>
  <p class="mt-3 text-sm leading-relaxed text-slate-600 sm:text-base"><%= t('pages.news.description') %></p>

  <ul class="mt-6 space-y-3">
    <li class="rounded-2xl border border-slate-200 p-4">
      <p class="text-xs font-semibold uppercase tracking-wider text-emerald-700"><%= t('pages.news.items.item1_tag') %></p>
      <h3 class="mt-1 font-bold text-slate-900"><%= t('pages.news.items.item1_title') %></h3>
      <p class="mt-1 text-sm text-slate-600"><%= t('pages.news.items.item1_body') %></p>
    </li>
    <li class="rounded-2xl border border-slate-200 p-4">
      <p class="text-xs font-semibold uppercase tracking-wider text-amber-700"><%= t('pages.news.items.item2_tag') %></p>
      <h3 class="mt-1 font-bold text-slate-900"><%= t('pages.news.items.item2_title') %></h3>
      <p class="mt-1 text-sm text-slate-600"><%= t('pages.news.items.item2_body') %></p>
    </li>
  </ul>
</section>
