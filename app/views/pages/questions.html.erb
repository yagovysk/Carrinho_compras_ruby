<section class="rounded-3xl border border-slate-200 bg-white/90 p-6 shadow-sm sm:p-8">
  <h2 class="text-2xl font-extrabold text-slate-900 sm:text-3xl"><%= t('pages.questions.title') %></h2>
  <p class="mt-3 text-sm leading-relaxed text-slate-600 sm:text-base"><%= t('pages.questions.description') %></p>

  <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
    <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
      <h3 class="font-bold text-slate-900"><%= t('pages.questions.faq.checkout_title') %></h3>
      <p class="mt-2 text-sm text-slate-600"><%= t('pages.questions.faq.checkout_body') %></p>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
      <h3 class="font-bold text-slate-900"><%= t('pages.questions.faq.payment_title') %></h3>
      <p class="mt-2 text-sm text-slate-600"><%= t('pages.questions.faq.payment_body') %></p>
    </div>
  </div>
</section>
