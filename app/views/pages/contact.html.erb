<section class="rounded-3xl border border-slate-200 bg-white/90 p-6 shadow-sm sm:p-8">
  <h2 class="text-2xl font-extrabold text-slate-900 sm:text-3xl"><%= t('pages.contact.title') %></h2>
  <p class="mt-3 text-sm leading-relaxed text-slate-600 sm:text-base"><%= t('pages.contact.description') %></p>

  <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
    <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
      <p class="text-sm font-semibold text-slate-900"><%= t('pages.contact.email_label') %></p>
      <p class="mt-1 text-sm text-slate-600">support@pragmaticshelf.dev</p>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
      <p class="text-sm font-semibold text-slate-900"><%= t('pages.contact.hours_label') %></p>
      <p class="mt-1 text-sm text-slate-600"><%= t('pages.contact.hours_value') %></p>
    </div>
  </div>
</section>
