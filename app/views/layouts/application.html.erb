<!DOCTYPE html>
<html>
  <head>
    <title><%= t('layout.page_title') %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "inter-font", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-shop-pattern text-slate-900 antialiased">
    <header class="border-b border-slate-200/70 bg-white/80 backdrop-blur-sm">
      <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-3">
          <%= image_tag 'logo.svg', alt: 'The Pragmatic Bookshelf', class: 'h-10 w-10 rounded-xl bg-emerald-50 p-1.5 ring-1 ring-emerald-200' %>
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-700"><%= t('layout.brand') %></p>
            <h1 class="text-lg font-bold leading-tight text-slate-900 sm:text-xl"><%= @page_title || t('layout.store_title') %></h1>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <p class="hidden rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-900 md:block"><%= t('layout.fast_checkout') %></p>
          <div class="flex items-center gap-1 rounded-xl border border-slate-200 bg-white p-1 shadow-sm">
            <%= button_to 'EN',
                          change_locale_path(locale: 'en'),
                          method: :post,
                          class: "rounded-lg px-2.5 py-1 text-xs font-bold transition #{I18n.locale.to_s == 'en' ? 'bg-emerald-600 text-white' : 'text-slate-700 hover:bg-slate-100'}" %>
            <%= button_to 'PT',
                          change_locale_path(locale: 'pt-BR'),
                          method: :post,
                          class: "rounded-lg px-2.5 py-1 text-xs font-bold transition #{I18n.locale.to_s == 'pt-BR' ? 'bg-emerald-600 text-white' : 'text-slate-700 hover:bg-slate-100'}" %>
          </div>
        </div>
      </div>
    </header>

    <section class="mx-auto grid max-w-7xl gap-6 px-4 pb-8 pt-6 sm:px-6 lg:grid-cols-[320px,1fr] lg:px-8">
      <aside class="space-y-5 lg:sticky lg:top-5 lg:self-start">
        <div id="cart">
          <%= render partial: 'carts/cart', locals: { cart: @cart } %>
        </div>

        <nav class="rounded-2xl border border-slate-200 bg-white/90 p-4 shadow-sm">
          <ul class="grid grid-cols-2 gap-2 text-sm font-medium sm:grid-cols-4 lg:grid-cols-1">
            <li><%= link_to t('layout.nav.home'), store_index_path, class: 'nav-link' %></li>
            <li><%= link_to t('layout.nav.questions'), questions_path, class: 'nav-link' %></li>
            <li><%= link_to t('layout.nav.news'), news_path, class: 'nav-link' %></li>
            <li><%= link_to t('layout.nav.contact'), contact_path, class: 'nav-link' %></li>
          </ul>
        </nav>
      </aside>

      <main class="min-w-0">
        <%= yield %>
      </main>
    </section>
  </body>
</html>
