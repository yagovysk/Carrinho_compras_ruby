<% if cart && !cart.line_items.empty? %>
  <div id="<%= dom_id cart %>" class="cart-shell p-4 sm:p-5">
    <div class="mb-3 flex items-center justify-between gap-3 border-b border-slate-200 pb-3">
      <h2 class="text-lg font-bold text-slate-900"><%= t('cart.title') %></h2>
      <span class="rounded-full bg-emerald-100 px-2.5 py-1 text-xs font-semibold text-emerald-800"><%= t('cart.items_count', count: cart.line_items.sum(:quantity)) %></span>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full text-sm text-slate-700">
        <tbody class="divide-y divide-slate-100">
          <%= render cart.line_items %>
        </tbody>
        <tfoot>
          <tr>
            <th class="pt-3 text-left text-sm font-semibold text-slate-700" colspan="3"><%= t('cart.total') %></th>
            <td class="pt-3 text-right text-base font-extrabold text-slate-900"><%= number_to_currency(cart.total_price) %></td>
          </tr>
        </tfoot>
      </table>
    </div>

    <div class="mt-4 grid grid-cols-1 gap-2 sm:grid-cols-2">
      <%= button_to t('cart.empty_cart'), cart, method: :delete, class: 'btn-ghost w-full' %>
      <%= link_to t('cart.checkout'), new_order_path, class: 'btn-primary w-full' %>
    </div>
  </div>
<% else %>
  <div class="cart-shell p-4 sm:p-5">
    <h2 class="text-lg font-bold text-slate-900"><%= t('cart.title') %></h2>
    <p class="mt-2 text-sm text-slate-600"><%= t('cart.empty_state') %></p>
  </div>
<% end %>
