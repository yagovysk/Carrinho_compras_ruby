<div class="w-full space-y-6">
  <%= render 'notice' %>

  <section class="rounded-3xl border border-slate-200 bg-white/90 p-5 shadow-sm sm:p-8">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-emerald-700"><%= t('store.featured') %></p>
    <h2 class="mt-2 text-2xl font-extrabold text-slate-900 sm:text-4xl"><%= t('store.catalog_title') %></h2>
    <p class="mt-3 max-w-2xl text-sm leading-relaxed text-slate-600 sm:text-base">
      <%= t('store.catalog_description') %>
    </p>
  </section>

  <%= turbo_stream_from "products" %>

  <ul id="products" class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-3">
    <% cache @products do %>
      <%= render partial: "store/product", collection: @products, as: :product %>
    <% end %>
  </ul>
</div>
